# VibeCode service settings (all optional — SQLite defaults apply without these)

# Storage backend: auto | sqlite | json | postgres
# VIBECODE_STORAGE_BACKEND=sqlite

# Service bind address (default: 127.0.0.1 — localhost only)
# VIBECODE_SERVICE_HOST=127.0.0.1
# VIBECODE_SERVICE_PORT=8765

# Log level
# VIBECODE_LOG_LEVEL=INFO

# Postgres connection (only needed with VIBECODE_STORAGE_BACKEND=postgres)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vibecode

# Comma-separated list of allowed project paths (can also set via `vibecode project allow`)
# VIBECODE_PROJECT_ALLOWLIST=/home/user/my-project,/home/user/other-project
